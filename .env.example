# 1. Cơ sở dữ liệu (Database)
# Thay bằ̀ng thông tin từ Project Settings -> Database -> Connection string (URI)
# Lưu ý quan trọng: KHÔNG dùng ngoặc vuông []. 
# Nếu mật khẩu có ký tự đặc biệt như '@', phải đổi thành '%40'
DATABASE_URL="postgresql://postgres.your_project_id:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your_project_id:your_password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# 2. Bảo mật (Security)
# Chuỗi ngẫu nhiên dùng để mã hóa đăng nhập nội bộ
JWT_SECRET="doi-chuoi-nay-de-bao-mat-ung-dung"

# 3. Supabase API
# Lấy các thông số này tại mục Project Settings -> API
SUPABASE_URL="https://your_project_id.supabase.co"
SUPABASE_ANON_KEY="your_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"


# 4. Tài khoản quản trị Admin (Dùng cho lệnh seed chạy lần đầu tiên)
ADMIN_EMAIL="your-admin-email@example.com"
ADMIN_PASSWORD="your-strong-password"
